#. Name and summary taken from the desktop file.
#: ../data/easytag.appdata.xml.in.h:2 ../data/easytag.desktop.in.h:1
msgid "EasyTAG"
msgstr "EasyTAG"

#: ../data/easytag.appdata.xml.in.h:3 ../data/easytag.desktop.in.h:3
msgid "Edit audio file metadata"
msgstr "Аудио файлдың метадеректерін түзету"

#: ../data/easytag.appdata.xml.in.h:4
msgid ""
"View and edit tags for MP3, MP2, MP4/AAC, FLAC, Ogg Opus, Ogg Speex, Ogg "
"Vorbis, MusePack, Monkey's Audio and WavPack files."
msgstr ""
"MP3, MP2, MP4/AAC, FLAC, Ogg Opus, Ogg Speex, Ogg Vorbis, MusePack, Monkey's "
"Audio және WavPack файлдарының тегтерін қарау және түзету."

#: ../data/easytag.appdata.xml.in.h:5
msgid ""
"Look up albums in online databases, bulk edit tags, create playlists and "
"rename a collection of files."
msgstr ""
"Онлайн дерекқорлардан альбомдарды іздеу, тегтерді жаппай түзету, ойнату "
"тізімдерін жасау және файлдар жиынтығының атын өзгерту."

#: ../data/easytag.appdata.xml.in.h:6
msgid ""
"A simple and nice GTK+ interface makes tagging easier under GNU/Linux and "
"Windows."
msgstr ""
"Қарапайым және жағымды GTK+ интерфейсі GNU/Linux және Windows жүйелерінде "
"тегтерді белгілеуді жеңілдетеді."

#: ../data/easytag.desktop.in.h:2
msgid "Audio File Metadata Editor"
msgstr "Аудио файл метадеректерін түзетуші"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
